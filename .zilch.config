# Zilch Reference App Configuration
# This app demonstrates all Zilch Phase 1 + Phase 2 services

# GitHub Integration (required for Cloud Build)
github_owner=your-github-username
github_repo=zilch-reference-app

# GCP Settings
# Example from successful deployment:
# - Project ID: test-z-1-499406
# - App name: gulp-app (customize as needed)
# - Region: us-central1 (must be Always Free eligible)
gcp_project_id=your-gcp-project-id
app_name=zilch-reference-app
gcp_region=us-central1

# Phase 1 Optional Features
# Enabled services will be provisioned and injected as environment variables
# Example deployment enabled: Firestore + Secret Manager
enable_firestore=true
enable_secret_manager=true
enable_cloud_storage=false
enable_firebase_auth=false
enable_vertex_ai=false

# Phase 2: Cloud Build + GitOps (optional)
# When enabled, Cloud Build watches this GitHub repo for changes
# Every push to main automatically builds and deploys new images
enable_cloud_build=false
