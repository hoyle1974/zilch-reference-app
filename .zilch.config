# Zilch Reference App Configuration
# This app demonstrates all Zilch Phase 1 + Phase 2 services

# GitHub Integration (required for Cloud Build)
github_owner=hoyle1974
github_repo=zilch-reference-app

# GCP Settings
gcp_project_id=test-z-1-499406
app_name=zilch-reference-app
gcp_region=us-central1

# Phase 1 Optional Features
enable_firestore=true
enable_secret_manager=true
enable_cloud_storage=true
enable_firebase_auth=true
enable_vertex_ai=true

# Phase 2: Cloud Build + GitOps (optional)
enable_cloud_build=true
